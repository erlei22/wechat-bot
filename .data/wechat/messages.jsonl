{"id":"3436506997023549472","timestamp":"2026-06-23T07:39:02.845Z","type":7,"typeName":"Text","isText":true,"isRoom":true,"roomName":"徒步小分队","talkerName":"汜归","talkerAlias":"冬冬2","receiverName":"","text":"@二雷 徒步过程中怎么和人产生链接（男女分开诉述","self":false}

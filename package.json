{
  "name": "wechat-bot",
  "version": "1.0.2",
  "description": "wechat-bot",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "node ./cli.js",
    "start": "node ./cli.js",
    "format": "prettier --write ./src",
    "test": "node ./src/wechaty/testMessage.js",
    "test:analysis": "node ./src/analysis/__test__.js",
    "test:openai": "node ./src/openai/__test__.js",
    "wechat:analyze": "node ./cli.js analyze --stats-only",
    "lark:login": "node ./cli.js lark login",
    "opencli": "node ./cli.js opencli",
    "wx": "node ./cli.js wx",
    "prepare": "npx husky"
  },
  "lint-staged": {
    "*.{js,ts,md}": [
      "prettier --write"
    ]
  },
  "files": [
    "src",
    "./.env.example",
    "./cli.js",
    "./Dockerfile",
    "./Dockerfile.alpine",
    "./LICENSE.md",
    "./README.md",
    "./RECORD.md"
  ],
  "bin": {
    "wb": "./cli.js",
    "wechat-bot": "./cli.js"
  },
  "homepage": "https://github.com/wangrongding/wechat-bot/",
  "repository": {
    "type": "git",
    "url": "https://github.com/wangrongding/wechat-bot.git"
  },
  "author": "荣顶",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chinese-days": "^1.5.9",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "inquirer": "^9.2.16",
    "lunar-javascript": "^1.7.7",
    "openai": "^4.52.0",
    "qrcode-terminal": "^0.12.0",
    "remark": "^14.0.2",
    "strip-markdown": "^5.0.0",
    "wechaty": "^1.20.2",
    "wechaty-puppet-wechat": "^1.18.4",
    "wechaty-puppet-wechat4u": "^1.14.14"
  },
  "devDependencies": {
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "puppeteer": "13.5.1",
    "puppeteer-core": "13.5.1"
  }
}
